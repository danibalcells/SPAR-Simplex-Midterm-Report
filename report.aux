\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Comparison across all 6 HMM configurations. Top: belief-state probe $R^2$ by layer. Middle: KL divergence (renormalized over HMM tokens) vs.\ sequence position. Bottom: KL divergence (all vocabulary) vs.\ sequence position. Mess3 configurations (green shades) achieve the highest $R^2$ and fastest convergence; Fern configurations (blue shades) show slightly lower $R^2$ and higher residual KL due to the 2-token vocabulary.}}{13}{figure.6}\protected@file@percent }
\newlabel{fig:comparison_all_configs}{{6}{13}{Comparison across all 6 HMM configurations. Top: belief-state probe $R^2$ by layer. Middle: KL divergence (renormalized over HMM tokens) vs.\ sequence position. Bottom: KL divergence (all vocabulary) vs.\ sequence position. Mess3 configurations (green shades) achieve the highest $R^2$ and fastest convergence; Fern configurations (blue shades) show slightly lower $R^2$ and higher residual KL due to the 2-token vocabulary}{figure.6}{}}
\newlabel{fig:comparison_all_configs@cref}{{[figure][6][]6}{[1][12][]13}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces 2D PCA of residual stream activations across all 28 layers, colored by ground-truth belief state (RGB = $(b^{(1)}, b^{(2)}, b^{(3)})$). Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$) shows clear simplex geometry. Right: Fern ($x{=}0.63$) shows discernible but less crisp structure.}}{14}{figure.7}\protected@file@percent }
\newlabel{fig:pca_sweep}{{7}{14}{2D PCA of residual stream activations across all 28 layers, colored by ground-truth belief state (RGB = $(b^{(1)}, b^{(2)}, b^{(3)})$). Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$) shows clear simplex geometry. Right: Fern ($x{=}0.63$) shows discernible but less crisp structure}{figure.7}{}}
\newlabel{fig:pca_sweep@cref}{{[figure][7][]7}{[1][12][]14}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Predicted belief states from the best linear probe, plotted on the 2-simplex. Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$, layer~2) reproduces the fractal belief geometry with high fidelity. Right: Fern ($x{=}0.63$, layer~5) recovers the triangular structure despite the non-injective emission matrix, confirming genuine latent-state tracking.}}{14}{figure.8}\protected@file@percent }
\newlabel{fig:predicted_simplex}{{8}{14}{Predicted belief states from the best linear probe, plotted on the 2-simplex. Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$, layer~2) reproduces the fractal belief geometry with high fidelity. Right: Fern ($x{=}0.63$, layer~5) recovers the triangular structure despite the non-injective emission matrix, confirming genuine latent-state tracking}{figure.8}{}}
