\newlabel{fig:kl_over_sequence}{{2}{7}{KL divergence $D_{\mathrm {KL}}(\mathbf {p}_{\mathrm {opt}} \| \mathbf {q})$ (log scale, nats) between the Bayesian-optimal distribution and the model's output distribution over the first 500 tokens of a representative Mess3 sequence. Light blue: raw per-token KL; dark blue: smoothed KL (window $w=5$). The red dashed line indicates the convergence threshold (2\% of maximum KL). The green dashed lines mark the earliest allowed position (min\_position = 20) and the crossing point $t^* = 22$}{figure.2}{}}
\newlabel{fig:kl_over_sequence@cref}{{[figure][2][]2}{[1][7][]7}}
