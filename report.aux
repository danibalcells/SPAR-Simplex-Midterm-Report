\@writefile{toc}{\contentsline {paragraph}{Tuned lens sweep.}{10}{section*.18}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Comparison across all 6 HMM configurations. Top: belief-state probe $R^2$ by layer. Middle: KL divergence (renormalized over HMM tokens) vs.\ sequence position. Bottom: KL divergence (all vocabulary) vs.\ sequence position. Mess3 configurations (green shades) achieve the highest $R^2$ and fastest convergence; Fern configurations (blue shades) show slightly lower $R^2$ and higher residual KL due to the 2-token vocabulary.}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:comparison_all_configs}{{6}{11}{Comparison across all 6 HMM configurations. Top: belief-state probe $R^2$ by layer. Middle: KL divergence (renormalized over HMM tokens) vs.\ sequence position. Bottom: KL divergence (all vocabulary) vs.\ sequence position. Mess3 configurations (green shades) achieve the highest $R^2$ and fastest convergence; Fern configurations (blue shades) show slightly lower $R^2$ and higher residual KL due to the 2-token vocabulary}{figure.6}{}}
\newlabel{fig:comparison_all_configs@cref}{{[figure][6][]6}{[1][10][]11}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces 2D PCA of residual stream activations across all 28 layers, colored by ground-truth belief state (RGB = $(b^{(1)}, b^{(2)}, b^{(3)})$). Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$) shows clear simplex geometry. Right: Fern ($x{=}0.63$) shows discernible but less crisp structure.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:pca_sweep}{{7}{12}{2D PCA of residual stream activations across all 28 layers, colored by ground-truth belief state (RGB = $(b^{(1)}, b^{(2)}, b^{(3)})$). Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$) shows clear simplex geometry. Right: Fern ($x{=}0.63$) shows discernible but less crisp structure}{figure.7}{}}
\newlabel{fig:pca_sweep@cref}{{[figure][7][]7}{[1][10][]12}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Predicted belief states from the best linear probe, plotted on the 2-simplex. Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$, layer\nobreakspace  {}2) reproduces the fractal belief geometry with high fidelity. Right: Fern ($x{=}0.63$, layer\nobreakspace  {}5) recovers the triangular structure despite the non-injective emission matrix, confirming genuine latent-state tracking.}}{12}{figure.8}\protected@file@percent }
\newlabel{fig:predicted_simplex}{{8}{12}{Predicted belief states from the best linear probe, plotted on the 2-simplex. Left: Mess3 ($\alpha {=}0.6$, $x{=}0.15$, layer~2) reproduces the fractal belief geometry with high fidelity. Right: Fern ($x{=}0.63$, layer~5) recovers the triangular structure despite the non-injective emission matrix, confirming genuine latent-state tracking}{figure.8}{}}
\newlabel{fig:predicted_simplex@cref}{{[figure][8][]8}{[1][10][]12}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Causal use of belief states}{12}{subsection.3.3}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Activation patching.}{12}{section*.19}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Layer vs.\ KL(HMM $\|$ HMM-target tuned lens) vs.\ $R^2$ for all 6 HMM configurations. Black line (left axis): belief-state probe $R^2$. Colored dashed line (right axis): KL divergence. Both Mess3 and Fern achieve near-zero KL at the early layers where $R^2$ peaks.}}{13}{figure.9}\protected@file@percent }
\newlabel{fig:tuned_lens_sweep}{{9}{13}{Layer vs.\ KL(HMM $\|$ HMM-target tuned lens) vs.\ $R^2$ for all 6 HMM configurations. Black line (left axis): belief-state probe $R^2$. Colored dashed line (right axis): KL divergence. Both Mess3 and Fern achieve near-zero KL at the early layers where $R^2$ peaks}{figure.9}{}}
\newlabel{fig:tuned_lens_sweep@cref}{{[figure][9][]9}{[1][12][]13}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Crossing plot for activation patching. The $y$-axis shows mean KL divergence to the factual (blue) and counterfactual (orange) Bayesian-optimal distributions, as a function of the layer at which patching is applied. The crossover point indicates the layer at which the patched activations carry sufficient belief state information to shift the model's predictions toward the counterfactual.}}{13}{figure.10}\protected@file@percent }
\newlabel{fig:crossing}{{10}{13}{Crossing plot for activation patching. The $y$-axis shows mean KL divergence to the factual (blue) and counterfactual (orange) Bayesian-optimal distributions, as a function of the layer at which patching is applied. The crossover point indicates the layer at which the patched activations carry sufficient belief state information to shift the model's predictions toward the counterfactual}{figure.10}{}}
\newlabel{fig:crossing@cref}{{[figure][10][]10}{[1][12][]13}}
\@writefile{toc}{\contentsline {paragraph}{Factual--counterfactual discrepancy and token probability.}{14}{section*.20}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Activation patching KL vs.\ layer, split by token probability. Left: factual patches; right: counterfactual patches. In both panels, likely-token beliefs (blue) yield lower KL than unlikely-token beliefs (orange). The two panels are nearly identical, confirming that the factual--counterfactual distinction is not the relevant factor; token probability is.}}{14}{figure.11}\protected@file@percent }
\newlabel{fig:patching_token_prob}{{11}{14}{Activation patching KL vs.\ layer, split by token probability. Left: factual patches; right: counterfactual patches. In both panels, likely-token beliefs (blue) yield lower KL than unlikely-token beliefs (orange). The two panels are nearly identical, confirming that the factual--counterfactual distinction is not the relevant factor; token probability is}{figure.11}{}}
\newlabel{fig:patching_token_prob@cref}{{[figure][11][]11}{[1][14][]14}}
\@writefile{toc}{\contentsline {paragraph}{Decoder fidelity.}{14}{section*.21}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Normalized decoder MSE ($\lVert \mathbf  {a}_t - D(\mathbf  {b}_t) \rVert ^2 / \lVert \mathbf  {a}_t \rVert ^2$) vs.\ token probability $p_t$ at each layer. Each blue dot is one (sequence, position) pair; the red line shows the binned mean. At early-to-mid layers, low-probability tokens exhibit markedly higher reconstruction error, explaining why patching with beliefs corresponding to unlikely tokens yields worse results.}}{15}{figure.12}\protected@file@percent }
\newlabel{fig:decoder_fidelity}{{12}{15}{Normalized decoder MSE ($\lVert \mathbf {a}_t - D(\mathbf {b}_t) \rVert ^2 / \lVert \mathbf {a}_t \rVert ^2$) vs.\ token probability $p_t$ at each layer. Each blue dot is one (sequence, position) pair; the red line shows the binned mean. At early-to-mid layers, low-probability tokens exhibit markedly higher reconstruction error, explaining why patching with beliefs corresponding to unlikely tokens yields worse results}{figure.12}{}}
\newlabel{fig:decoder_fidelity@cref}{{[figure][12][]12}{[1][14][]15}}
