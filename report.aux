\newlabel{fig:four_stage_regression}{{14}{20}{Probed belief states at each residual stream stage, projected onto the 2-simplex. Each point is one sequence position (test set), colored by current token identity. From left to right: token embeddings map to three discrete directions; the attention output maps to the exponentially-weighted sum of past directions; post-attention maps to the constrained belief; post-MLP maps to the full Bayesian belief}{figure.14}{}}
\newlabel{fig:four_stage_regression@cref}{{[figure][14][]14}{[1][19][]20}{}{}{}}
