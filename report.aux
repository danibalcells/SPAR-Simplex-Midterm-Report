\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces PCA of layer-0 attention output, colored by the token at different lags. At $t{-}1$, three major groups separate. At $t{-}2$, nine sub-clusters emerge. At $t{-}0$ (current token), no separation is visible. This matches the prediction of the constrained belief update.}}{21}{figure.16}\protected@file@percent }
\newlabel{fig:fractal_hierarchy}{{16}{21}{PCA of layer-0 attention output, colored by the token at different lags. At $t{-}1$, three major groups separate. At $t{-}2$, nine sub-clusters emerge. At $t{-}0$ (current token), no separation is visible. This matches the prediction of the constrained belief update}{figure.16}{}}
\newlabel{fig:fractal_hierarchy@cref}{{[figure][16][]16}{[1][20][]21}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Exponential decay of past token influence. (a)~Between-group variance of attn\_out grouped by the token at lag~$k$, computed on the full 3072-d vectors and on PCA subspaces of 2, 5, and 10 dimensions; the implied $\zeta $ is consistent across subspaces, confirming the decay structure is concentrated in the leading principal components. (b)~Effective weight (Eq.~\ref {eq:effective_weight}) using Probe~A (attn\_out $\to $ expected attention output). (c)~Effective weight using Probe~B (attn\_out $\to $ full Bayesian beliefs, whose target contains no~$\zeta $). Red: fit to $k = 1$--$6$. Dashed: theoretical $\zeta = 0.55$.}}{21}{figure.17}\protected@file@percent }
\newlabel{fig:decay_combined}{{17}{21}{Exponential decay of past token influence. (a)~Between-group variance of attn\_out grouped by the token at lag~$k$, computed on the full 3072-d vectors and on PCA subspaces of 2, 5, and 10 dimensions; the implied $\zeta $ is consistent across subspaces, confirming the decay structure is concentrated in the leading principal components. (b)~Effective weight (Eq.~\ref {eq:effective_weight}) using Probe~A (attn\_out $\to $ expected attention output). (c)~Effective weight using Probe~B (attn\_out $\to $ full Bayesian beliefs, whose target contains no~$\zeta $). Red: fit to $k = 1$--$6$. Dashed: theoretical $\zeta = 0.55$}{figure.17}{}}
\newlabel{fig:decay_combined@cref}{{[figure][17][]17}{[1][21][]21}{}{}{}}
